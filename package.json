{
  "name": "berztech",
  "version": "1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:unit": "vitest run tests/unit tests/components",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage --reporter=html",
    "test:e2e": "playwright test",
    "test:lighthouse": "lhci autorun",
    "test:load:requests": "k6 run tests/load/api-requests.js",
    "test:load:blog": "k6 run tests/load/api-blog.js",
    "test:security": "vitest run tests/security/auth-bypass.test.ts tests/security/data-exposure.test.ts tests/security/idor.test.ts tests/security/input-injection.test.ts",
    "test:security:live": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && vitest run tests/security/integration\"",
    "test:security:live:rate": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && vitest run tests/security/integration/rate-limit-api.test.js\"",
    "test:security:live:sql": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && vitest run tests/security/integration/sql-injection-api.test.js\"",
    "test:security:live:xss": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && vitest run tests/security/integration/xss-api.test.js\"",
    "test:a11y": "vitest run tests/components/a11y",
    "test:a11y:e2e": "playwright test tests/e2e/a11y",
    "test:visual": "playwright test tests/e2e/visual",
    "test:visual:update": "playwright test tests/e2e/visual --update-snapshots",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@uiw/react-md-editor": "^4.0.11",
    "autoprefixer": "10.4.15",
    "clsx": "^2.0.0",
    "framer-motion": "^12.0.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^4.10.1",
    "tailwindcss": "3.3.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@faker-js/faker": "^10.3.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.1",
    "eslint-config-next": "^16.1.6",
    "fast-check": "^4.6.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^24.0.0",
    "msw": "^2.1.5",
    "vite": "^5.0.12",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
