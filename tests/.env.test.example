# tests/.env.test.example
# Copy this file to tests/.env.test and fill in your values
# DO NOT COMMIT the actual .env.test file with real credentials

# Supabase Configuration (required for integration tests)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin email for admin-only endpoints
ADMIN_EMAIL=admin@yourdomain.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# Test Credentials (for E2E tests)
TEST_CLIENT_EMAIL=testclient@example.com
TEST_CLIENT_PASSWORD=your-test-password
TEST_ADMIN_EMAIL=admin@yourdomain.com
TEST_ADMIN_PASSWORD=your-admin-password

# Playwright Configuration
PLAYWRIGHT_BASE_URL=http://localhost:3000
